<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soru Hazırla"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soru:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSoru"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Soruyu buraya yazın..."
            android:minLines="3"
            android:gravity="top"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şıklar (doğru cevap için yuvarlağa tıklayın):"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="10dp" />

        <!-- Şık A -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#1976D2"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="A)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <EditText
                android:id="@+id/etA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="A şıkkı"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Şık B -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#1976D2"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="B)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <EditText
                android:id="@+id/etB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="B şıkkı"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Şık C -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#1976D2"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="C)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <EditText
                android:id="@+id/etC"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="C şıkkı"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Şık D -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#1976D2"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="D)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <EditText
                android:id="@+id/etD"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="D şıkkı"
                android:background="@android:drawable/edit_text"
                android:padding="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnKaydet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Kaydet"
            android:textSize="18sp"
            android:backgroundTint="#1976D2" />

    </LinearLayout>
</ScrollView>
