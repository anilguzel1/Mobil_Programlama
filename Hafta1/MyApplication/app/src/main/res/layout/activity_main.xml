<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="339dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        android:background="#E2E8F0"
        android:gravity="bottom|end"
        android:padding="24dp"
        android:text=""
        android:textColor="#000000"
        android:textSize="56sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:columnCount="5"
        android:rowCount="4">

        <Button android:id="@+id/btn7" android:text="7" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn8" android:text="8" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn9" android:text="9" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnPlus" android:text="+" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>
        <Button android:id="@+id/btnFraction" android:text="a/b" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>

        <Button android:id="@+id/btn4" android:text="4" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn5" android:text="5" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn6" android:text="6" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnMinus" android:text="-" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>
        <Button android:id="@+id/btnInverse" android:text="1/x" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>

        <Button android:id="@+id/btn1" android:text="1" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn2" android:text="2" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn3" android:text="3" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnMultiply" android:text="*" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>
        <Button android:id="@+id/btnPower" android:text="x^y" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>

        <Button android:id="@+id/btn0" android:text="0" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnClear" android:text="C" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnEquals" android:text="=" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>
        <Button android:id="@+id/btnDivide" android:text="/" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>
        <Button android:id="@+id/btnRoot" android:text="y√" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="4dp" android:backgroundTint="@color/black"/>

    </GridLayout>
</LinearLayout>