<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F2F2F2">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#DCE8F4"
        android:gravity="bottom|end"
        android:padding="16dp"
        android:textColor="#000000"
        android:textSize="48sp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
        <Button android:id="@+id/btn7" android:text="7" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn8" android:text="8" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn9" android:text="9" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btnPlus" android:text="+" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnYuzde" android:text="%" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#FFFFFF" android:textColor="#D32F2F" app:strokeWidth="2dp" app:strokeColor="#D32F2F"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
        <Button android:id="@+id/btn4" android:text="4" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn5" android:text="5" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn6" android:text="6" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btnMinus" android:text="-" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnYarim" android:text="½" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#FFFFFF" android:textColor="#D32F2F" app:strokeWidth="2dp" app:strokeColor="#D32F2F"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
        <Button android:id="@+id/btn1" android:text="1" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn2" android:text="2" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btn3" android:text="3" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btnMultiply" android:text="*" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnKare" android:text="x²" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#FFFFFF" android:textColor="#D32F2F" app:strokeWidth="2dp" app:strokeColor="#D32F2F"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
        <Button android:id="@+id/btn0" android:text="0" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp"/>
        <Button android:id="@+id/btnClear" android:text="C" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnEquals" android:text="=" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnDivide" android:text="/" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#000000"/>
        <Button android:id="@+id/btnKok" android:text="√x" android:layout_width="65dp" android:layout_height="65dp" android:layout_margin="4dp" app:cornerRadius="35dp" android:backgroundTint="#FFFFFF" android:textColor="#D32F2F" app:strokeWidth="2dp" app:strokeColor="#D32F2F"/>
    </LinearLayout>

</LinearLayout>